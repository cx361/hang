# Uncomment this line to define a global platform for your project
platform :ios, '14.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    target.build_configurations.each do |config|
      # Das hier stellt sicher, dass alle Pods die gleiche iOS-Version nutzen
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      # Verhindert Fehler bei Apple Silicon Simulatoren
      config.build_settings['ONLY_ACTIVE_ARCH'] = 'YES'
    end
  end

  # Fix: force-load libh3.a so all C symbols (e.g. degsToRads) are available
  # for Dart FFI's DynamicLibrary.process() lookup at runtime.
  #
  # Using a helper variable H3_FORCE_LOAD avoids the bug where setting
  # OTHER_LDFLAGS[sdk=iphoneos*] replaces the unconditional OTHER_LDFLAGS
  # (losing -ObjC, -l"h3", all framework flags). Instead OTHER_LDFLAGS stays
  # unconditional and expands $(H3_FORCE_LOAD) which is SDK-conditional.
  %w[Pods-Runner].each do |target_name|
    %w[debug release].each do |config_name|
      xcconfig_path = File.join(installer.sandbox.root.to_s, 'Target Support Files', target_name, "#{target_name}.#{config_name}.xcconfig")
      next unless File.exist?(xcconfig_path)

      contents = File.read(xcconfig_path)
      next if contents.include?('H3_FORCE_LOAD')

      # Remove old broken conditional flags if present from a previous install
      contents = contents.gsub(/\nOTHER_LDFLAGS\[sdk=.*?\] = .*/, '')

      sim_lib  = '"$(PODS_ROOT)/../.symlinks/plugins/h3_flutter/darwin/Libs/h3.xcframework/ios-arm64_x86_64-simulator/libh3.a"'
      ios_lib  = '"$(PODS_ROOT)/../.symlinks/plugins/h3_flutter/darwin/Libs/h3.xcframework/ios-arm64/libh3.a"'

      # Append the sdk-conditional helper and reference it from OTHER_LDFLAGS
      contents = contents.gsub(/^(OTHER_LDFLAGS = .*)$/) do |match|
        <<~XCCONFIG.chomp
          H3_FORCE_LOAD[sdk=iphoneos*] = -force_load #{ios_lib}
          H3_FORCE_LOAD[sdk=iphonesimulator*] = -force_load #{sim_lib}
          #{match} $(H3_FORCE_LOAD)
        XCCONFIG
      end

      File.write(xcconfig_path, contents)
    end
  end
end
